# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Google Cloud credentials
client_secret*.json

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE
.vscode/
.idea/
.env*.local

# Crawl audit reports (generated by npm run crawl-audit)
crawl-audit-report.json

# Visuals pipeline cache (generated by npm run visuals:generate)
.visuals-cache/

# Local audit reports
pagespeed-report.json

# Local research artifacts (docx/xlsx not checked in)
competitive-research/

# Python caches (skill scripts)
__pycache__/
scripts/internal-links/inventory.json
scripts/internal-links/patches/
