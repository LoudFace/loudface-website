# Sanity CMS Configuration
# Copy this file to .env and fill in your values
# On Vercel, set these in Settings → Environment Variables

# Sanity Project ID and Dataset
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API Token (for write operations / migration)
# Get from: https://www.sanity.io/manage → API → Tokens
SANITY_API_TOKEN=your_token_here

# PostHog Analytics
# Get this from: PostHog Dashboard → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Cal.com Webhook
# Shared secret used to verify webhook signatures from Cal.com
# Generate with: openssl rand -hex 32
# Register webhook at: https://app.cal.com/settings/developer/webhooks
#   URL: https://<your-domain>/api/webhooks/cal
#   Triggers: BOOKING_CREATED, BOOKING_RESCHEDULED, BOOKING_CANCELLED
CAL_WEBHOOK_SECRET=your_cal_webhook_secret_here

# DataForSEO API (AI Visibility Audit)
# Get credentials from: https://app.dataforseo.com/
DATAFORSEO_LOGIN=your_login_here
DATAFORSEO_PASSWORD=your_password_here

# Google PageSpeed Insights API Key (for pagespeed-audit script)
# Get from: Google Cloud Console → APIs & Services → Credentials → Create API Key
# Enable "PageSpeed Insights API" first. Free: 25,000 queries/day with key.
PAGESPEED_API_KEY=

# Redis (for audit result storage)
# Auto-populated by Vercel Storage integration
REDIS_URL=
